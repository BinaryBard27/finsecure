# FinSecure API — Environment Configuration
# Copy this to .env and fill in real values.
# NEVER commit .env to git — it's in .gitignore.
#
# Validate this file with env-check before running:
#   env-check --schema schema.json --env .env --strict

# ── Database ─────────────────────────────────────────────────────────────────
# asyncpg driver required — note the postgresql+asyncpg:// prefix
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/finsecure

# ── Auth & Encryption ─────────────────────────────────────────────────────────
# Generate JWT secret: openssl rand -hex 32
JWT_SECRET_KEY=replace-this-with-a-secure-random-string-min-32-chars

# AES key MUST be exactly 32 characters for AES-256
# Generate: openssl rand -hex 16   (gives exactly 32 hex chars)
AES_ENCRYPTION_KEY=replace-this-exactly-32-chars!!

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=dev
PORT=8080

# ── Fraud Detection ───────────────────────────────────────────────────────────
FRAUD_SCORE_THRESHOLD=2.5
MAX_TRANSFER_AMOUNT=500000
